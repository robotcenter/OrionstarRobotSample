<?xml version="1.0" encoding="utf-8"?>
<!-- 带波纹效果的圆角按钮 -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#80FFFFFF">  <!-- 半透明白色波纹效果 -->

    <item android:id="@android:id/mask">
        <!-- 波纹的遮罩形状（决定波纹的边界）-->
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>  <!-- 遮罩颜色（不影响视觉）-->
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <item>
        <!-- 按钮正常状态的背景 -->
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>  <!-- 透明背景 -->
            <stroke android:width="1dp" android:color="#FFFFFF"/>  <!-- 白色边框 -->
            <corners android:radius="16dp"/>  <!-- 圆角 -->
        </shape>
    </item>

</ripple>
